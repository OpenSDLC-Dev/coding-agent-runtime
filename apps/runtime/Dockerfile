# syntax=docker/dockerfile:1
# Base image: Node 22 LTS on Debian 12 (bookworm). Uses slim, not alpine -- the CLI bundled with the SDK depends on glibc/libstdc++.
FROM node:22-bookworm-slim

# ---- System layer: coding tools + gh (GitHub official keyring apt source) ----
ENV DEBIAN_FRONTEND=noninteractive
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        git \
        ripgrep \
        jq \
        curl \
        ca-certificates \
        wget \
        gnupg \
        libstdc++6; \
    mkdir -p -m 755 /etc/apt/keyrings; \
    out=$(mktemp); \
    wget -nv -O"$out" https://cli.github.com/packages/githubcli-archive-keyring.gpg; \
    cat "$out" | tee /etc/apt/keyrings/githubcli-archive-keyring.gpg > /dev/null; \
    chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg; \
    mkdir -p -m 755 /etc/apt/sources.list.d; \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        | tee /etc/apt/sources.list.d/github-cli.list > /dev/null; \
    apt-get update; \
    apt-get install -y --no-install-recommends gh; \
    rm -rf /var/lib/apt/lists/*

# ---- uv (astral official script) + Python 3.12 (installed onto the system PATH so non-root users can use it too) ----
# uv is installed to /usr/local/bin (system PATH). Python 3.12 must explicitly specify a shared directory:
#   UV_PYTHON_INSTALL_DIR=/opt/uv-python  installs the interpreter into a shared directory (the default is root's home, which the app user cannot read)
#   UV_PYTHON_BIN_DIR=/usr/local/bin      places the python/python3/python3.12 symlinks generated by --default onto the system PATH
# Otherwise the app user has no python3 on PATH, and uv cannot find that interpreter either.
RUN set -eux; \
    curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin UV_UNMANAGED_INSTALL=/usr/local/bin sh; \
    env UV_PYTHON_INSTALL_DIR=/opt/uv-python UV_PYTHON_BIN_DIR=/usr/local/bin uv python install 3.12 --default; \
    chmod -R a+rX /opt/uv-python

# ---- Install Claude Code CLI standalone (decoupled from the Agent SDK) ----
# The SDK and CLI communicate over stdio/stream-json; the CLI is updated more frequently, independently of SDK upgrades.
# Here we install the [standalone] native CLI binary globally; at runtime the SDK's pathToClaudeCodeExecutable points at it (see ENV RUNTIME_CLAUDE_CLI_PATH).
# The version uses a build ARG so it can be bumped independently (docker build --build-arg CLAUDE_CODE_VERSION=...).
# Note: the platform binary bundled with the SDK is not baked into the image -- the pnpm install below uses --no-optional to skip its optional platform packages.
ARG CLAUDE_CODE_VERSION=2.1.162
RUN set -eux; \
    npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}; \
    chmod -R a+rX /usr/local/lib/node_modules/@anthropic-ai 2>/dev/null || true; \
    ls -l /usr/local/bin/claude; \
    DISABLE_AUTOUPDATER=1 /usr/local/bin/claude --version

# ---- corepack enables pnpm (turn off the download interactive prompt to avoid a build hang) ----
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
RUN corepack enable

# ---- Fixed UID/GID non-root user (aligned with bind mount chown) ----
RUN groupadd --gid 10001 app \
    && useradd --uid 10001 --gid 10001 --create-home --shell /bin/bash app

# ---- Application directory + mountable directories ----
WORKDIR /app
RUN mkdir -p /workspace /claude-config \
    && chown -R app:app /app /workspace /claude-config

# ---- COPY the manifest first to leverage layer caching ----
COPY --chown=app:app pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY --chown=app:app apps/runtime/package.json ./apps/runtime/package.json

USER app
# --no-optional: skip optionalDependencies (including the CLI binary bundled with @anthropic-ai/claude-agent-sdk-<platform>).
# At runtime we always use the standalone CLI installed above (pathToClaudeCodeExecutable is always set), so the SDK's bundled binary does not need to be packaged.
RUN pnpm install --frozen-lockfile --no-optional --filter @app/runtime...

# ---- COPY the remaining source and build ----
COPY --chown=app:app . .
RUN pnpm --filter @app/runtime build

# entrypoint needs the executable bit (COPY does not guarantee it is preserved)
USER root
RUN chmod +x /app/apps/runtime/container/entrypoint.sh
USER app

# ---- Runtime ENV ----
# RUNTIME_CLAUDE_CLI_PATH: points at the standalone Claude Code CLI (the core of the decoupling). The SDK spawns it based on this,
# no longer using the bundled binary (which was excluded by --no-optional).
ENV DISABLE_AUTOUPDATER=1 \
    CLAUDE_CONFIG_DIR=/claude-config \
    HOME=/home/app \
    PORT=8080 \
    RUNTIME_HOSTNAME=0.0.0.0 \
    RUNTIME_CLAUDE_CLI_PATH=/usr/local/bin/claude \
    UV_PYTHON_INSTALL_DIR=/opt/uv-python \
    NPM_CONFIG_CACHE=/tmp/.npm \
    UV_CACHE_DIR=/tmp/.uv \
    XDG_CACHE_HOME=/tmp/.cache \
    XDG_CONFIG_HOME=/tmp/.config \
    XDG_DATA_HOME=/tmp/.local/share \
    GH_CONFIG_DIR=/tmp/.config/gh \
    GIT_CONFIG_GLOBAL=/tmp/.gitconfig \
    PNPM_HOME=/tmp/.pnpm \
    PATH=/home/app/.local/share/pnpm:/home/app/.local/bin:/usr/local/bin:$PATH

EXPOSE 8080

# ---- Defense in depth: remove curl/wget that are only needed at build time (at runtime they are already blocked by the allowlist + disallowedTools; here we do not even leave the binaries) ----
USER root
RUN apt-get purge -y curl wget && apt-get autoremove -y && rm -rf /var/lib/apt/lists/*
USER app

ENTRYPOINT ["/app/apps/runtime/container/entrypoint.sh"]
