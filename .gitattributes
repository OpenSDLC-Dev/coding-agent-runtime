# Enforce LF line endings repo-wide. eol=lf takes precedence over core.autocrlf, preventing Windows checkout from converting to CRLF
# which would break biome and corrupt the container entrypoint shebang. Binaries are auto-detected by text=auto and unaffected.
* text=auto eol=lf
*.sh text eol=lf
entrypoint.sh text eol=lf
Dockerfile text eol=lf
