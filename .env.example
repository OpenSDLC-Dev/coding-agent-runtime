# ---- 模型后端（Agent SDK / CLI 透传）----
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=sk-replace-me
RUNTIME_DEFAULT_MODEL=MiniMax-M3

# Claude 推理强度 effort：low/medium/high/xhigh/max。runtime 默认 max（最大推理深度；SDK 自身默认仅 high）。
# 非法值回退 max。注意：并非所有模型后端都支持 effort（不支持则忽略该参数）。
RUNTIME_EFFORT=max

# ---- 服务自身 ----
PORT=8080
# 监听地址。安全默认仅绑回环 127.0.0.1；容器内由 Dockerfile 显式设 0.0.0.0（docker -p 需要）。
# 本地非容器直跑时留空即安全。
RUNTIME_HOSTNAME=127.0.0.1
JAEGER_BASE_URL=http://localhost:16686
# ---- OTel（仅 docker-compose 起栈时生效；裸 docker run 不设 OTEL_EXPORTER_OTLP_ENDPOINT 则 telemetry 自动 off）----
# 这些由 docker-compose.yml 注入，无需在 .env 配置；列此仅作说明：
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
#   CLAUDE_CODE_ENABLE_TELEMETRY=1 / CLAUDE_CODE_ENHANCED_TELEMETRY_BETA=1 / CLAUDE_CODE_PROPAGATE_TRACEPARENT=1
INCLUDE_PARTIAL_MESSAGES=0
# P1：可选 model 白名单（逗号分隔；留空=不限制）。显式请求不在白名单的 model 会被 400 拒绝。
RUNTIME_ALLOWED_MODELS=
# P1：CORS 允许的前端 origin（可信网络可 *；多个用逗号分隔）。
CORS_ORIGINS=*
# 独立 Claude Code CLI 路径（SDK/CLI 解耦）。容器内 Dockerfile 已设为 /usr/local/bin/claude——
# 【勿在此置空】否则 --env-file 会覆盖容器默认为空，导致 SDK 去找已被 --no-optional 排除的自带二进制而报错。
# 仅本地非容器、且想显式指定独立 CLI 时才取消注释并填路径；留注释则本地回退 SDK 自带二进制。
#RUNTIME_CLAUDE_CLI_PATH=/usr/local/bin/claude

# ---- 容器内 agent 的 VCS 认证（复用本机 gh：用 `gh auth token` 取值填入）----
GH_TOKEN=
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
GIT_COMMITTER_NAME=
GIT_COMMITTER_EMAIL=
