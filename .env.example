# ---- Model backend (passed through to the Agent SDK / CLI) ----
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=sk-your-key-here
RUNTIME_DEFAULT_MODEL=MiniMax-M3

# Reasoning effort: low/medium/high/xhigh/max. The runtime defaults to max (deepest reasoning;
# the SDK's own default is only high). Invalid values fall back to max. Note: not every model
# backend supports effort (unsupported backends ignore it).
RUNTIME_EFFORT=max

# ---- The service itself ----
PORT=8080
# Bind address. Secure default binds loopback 127.0.0.1 only; inside the container the Dockerfile
# sets 0.0.0.0 explicitly (required for docker -p). Leave as-is for a safe local run.
RUNTIME_HOSTNAME=127.0.0.1
JAEGER_BASE_URL=http://localhost:16686
# ---- OTel (only active when the docker-compose stack is up; a bare `docker run` without
# OTEL_EXPORTER_OTLP_ENDPOINT auto-disables telemetry) ----
# These are injected by docker-compose.yml — no need to set them here; listed for reference only:
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
#   CLAUDE_CODE_ENABLE_TELEMETRY=1 / CLAUDE_CODE_ENHANCED_TELEMETRY_BETA=1 / CLAUDE_CODE_PROPAGATE_TRACEPARENT=1
INCLUDE_PARTIAL_MESSAGES=0
# Optional model allowlist (comma-separated; empty = unrestricted). Explicitly requesting a model
# that is not in the list is rejected with 400.
RUNTIME_ALLOWED_MODELS=
# CORS-allowed front-end origins (a trusted network may use *; comma-separate multiple).
CORS_ORIGINS=*
# Standalone Claude Code CLI path (SDK/CLI decoupling). Inside the container the Dockerfile already
# sets it to /usr/local/bin/claude — DO NOT set it to empty here, or --env-file would override the
# container default to empty and the SDK would look for the bundled binary that --no-optional
# excluded, causing an error. Uncomment and set a path only for a local non-container run where you
# want to point at a standalone CLI; leave it commented to fall back to the SDK's bundled binary.
#RUNTIME_CLAUDE_CLI_PATH=/usr/local/bin/claude

# ---- Local (non-container) runs only ----
# The agent's working dir (where it reads/writes files) and the Claude Code CLI config dir both
# default to container paths (/workspace, /claude-config) that don't exist locally, so file-writing
# turns fail when running outside Docker. For a local run, point them at real, writable local dirs.
# WARNING: keep these COMMENTED if the same .env is also used by docker-compose (env_file) — a host
# path injected into the container would break it. Inside the container the image/compose set them.
#RUNTIME_CWD=/absolute/path/to/your/workspace
#CLAUDE_CONFIG_DIR=/absolute/path/to/a/writable/config/dir

# ---- VCS auth for the in-container agent (reuse your host gh: fill in `gh auth token`) ----
GH_TOKEN=
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
GIT_COMMITTER_NAME=
GIT_COMMITTER_EMAIL=

# —— Production guards (hosting hardening; see README "Hosting" section) ——
# Runaway backstop: max agentic turns (API round-trips) per turn. The Agent SDK has NO top-level
# session timeout, so this bounds a looping agent. Default 100; 0 = unlimited (not recommended).
# RUNTIME_MAX_TURNS=100
# Optional wall-clock deadline per turn (ms). When >0, the turn is aborted at the deadline
# (emits an `aborted` event). Default 0 = disabled.
# RUNTIME_TURN_TIMEOUT_MS=0
# Admission control: max concurrent in-flight turns; beyond this, new turns get HTTP 429. Bounds
# subprocess RAM so concurrent sessions cannot OOM the container. Default 2 (≈1 GiB/session vs the
# 2g mem_limit); 0 = unlimited. Raise it together with the container mem_limit.
# RUNTIME_MAX_CONCURRENT_TURNS=2
# Idle-session GC: drop a session (and reclaim its on-disk transcript) after it is idle this long (ms).
# Default 0 = disabled. Set e.g. 86400000 (24h) on a long-running container to keep disk in check.
# RUNTIME_SESSION_TTL_MS=0
# How often the idle-session GC sweep runs (ms). Default 3600000 (1h); only active when TTL > 0.
# RUNTIME_GC_INTERVAL_MS=3600000

# —— P3 security ——
# Bash command allowlist (comma/space separated; empty = built-in default). Matches argv[0] basename only.
# RUNTIME_BASH_ALLOWLIST=git gh node npm npx pnpm python3 uv uvx ls cat rg
# SSE heartbeat interval (ms; 0 = disabled). Default 20000, prevents idle reverse-proxy disconnects.
# RUNTIME_SSE_HEARTBEAT_MS=20000
# Optional egress domain allowlist (only effective when container/egress-allowlist.sh is enabled).
# EGRESS_ALLOW_DOMAINS=github.com,api.github.com,registry.npmjs.org,pypi.org

# —— Extensions ——
# Optional path to a declarative extensions manifest (JSON) defining external MCP servers,
# local plugin dirs, skill enablement, and discovery dirs. In-process custom tools / hook
# callbacks instead go in apps/runtime/src/extensions/builtin.ts (code tier). Unset = none.
# See docs/extensions.md (the full authoring guide). Extensions are operator-trusted; their
# MCP/custom tools run OUTSIDE the Bash allowlist, so container hardening is the backstop.
# RUNTIME_EXTENSIONS_FILE=/path/to/extensions.json
