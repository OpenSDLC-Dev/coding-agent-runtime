# ---- 模型后端（Agent SDK / CLI 透传）----
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=sk-replace-me
RUNTIME_DEFAULT_MODEL=MiniMax-M3

# ---- 服务自身 ----
PORT=8080
# 监听地址。安全默认仅绑回环 127.0.0.1；容器内由 Dockerfile 显式设 0.0.0.0（docker -p 需要）。
# 本地非容器直跑时留空即安全。
RUNTIME_HOSTNAME=127.0.0.1
JAEGER_BASE_URL=http://localhost:16686
INCLUDE_PARTIAL_MESSAGES=0
# P1：可选 model 白名单（逗号分隔；留空=不限制）。显式请求不在白名单的 model 会被 400 拒绝。
RUNTIME_ALLOWED_MODELS=
# P1：CORS 允许的前端 origin（可信网络可 *；多个用逗号分隔）。
CORS_ORIGINS=*
# 独立 Claude Code CLI 路径（SDK/CLI 解耦）。容器内由 Dockerfile 设为 /usr/local/bin/claude；
# 本地非容器留空 → 回退 SDK 自带二进制。
RUNTIME_CLAUDE_CLI_PATH=

# ---- 容器内 agent 的 VCS 认证（复用本机 gh：用 `gh auth token` 取值填入）----
GH_TOKEN=
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
GIT_COMMITTER_NAME=
GIT_COMMITTER_EMAIL=
