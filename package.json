{
  "name": "coding-agent-runtime",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @app/runtime dev",
    "dev:web": "pnpm --filter @app/web dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "verify": "biome ci . && pnpm -r run typecheck && pnpm -r run test && pnpm -r run build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<0.28.1": "^0.28.1"
    }
  }
}
